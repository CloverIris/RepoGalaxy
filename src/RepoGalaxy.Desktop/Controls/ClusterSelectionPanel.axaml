<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RepoGalaxy.Desktop.ViewModels"
             x:Class="RepoGalaxy.Desktop.Controls.ClusterSelectionPanel"
             Width="400"
             Background="#0D1117"
             BorderBrush="#30363D"
             BorderThickness="1"
             CornerRadius="12">
  
  <Grid RowDefinitions="Auto,*,Auto">
    
    <!-- 头部 -->
    <Border Grid.Row="0" 
            Background="#161B22"
            BorderBrush="#30363D"
            BorderThickness="0,0,0,1"
            Padding="16,12"
            CornerRadius="12,12,0,0">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="📦" FontSize="16" VerticalAlignment="Center"/>
          <TextBlock Name="ClusterNameText" Text="相似项目"
                     FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
          <TextBlock Name="MemberCountText" Text="(0 个项目)"
                     FontSize="13" Foreground="#8B949E" VerticalAlignment="Center"/>
        </StackPanel>
        
        <Button Grid.Column="1"
                Name="SelectAllButton"
                Content="全选"
                Margin="0,0,8,0"
                Padding="12,4"
                Background="Transparent"
                BorderBrush="#30363D"
                BorderThickness="1"/>
        
        <Button Grid.Column="2"
                Name="CloseButton"
                Content="✕"
                Width="28"
                Height="28"
                Background="Transparent"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"/>
      </Grid>
    </Border>
    
    <!-- 成员列表 -->
    <ScrollViewer Grid.Row="1" 
                  MaxHeight="400"
                  VerticalScrollBarVisibility="Auto">
      <WrapPanel Name="MembersPanel" Orientation="Horizontal" Margin="12"/>
    </ScrollViewer>
    
    <!-- 底部操作栏 -->
    <Border Grid.Row="2"
            Background="#161B22"
            BorderBrush="#30363D"
            BorderThickness="0,1,0,0"
            Padding="16,12"
            CornerRadius="0,0,12,12">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Grid.Column="0"
                   Name="SelectedCountText"
                   Text="已选 0 项"
                   VerticalAlignment="Center"
                   Foreground="#8B949E"/>
        
        <StackPanel Grid.Column="2" 
                    Orientation="Horizontal" 
                    Spacing="8">
          <Button Name="BookmarkButton"
                  Content="🔖 收藏"
                  Height="36"
                  Padding="16,0"
                  CornerRadius="6"
                  Background="#21262D"
                  BorderBrush="#30363D"
                  BorderThickness="1"/>
          <Button Name="CompareButton"
                  Content="📊 比较"
                  Height="36"
                  Padding="16,0"
                  CornerRadius="6"
                  Background="#21262D"
                  BorderBrush="#30363D"
                  BorderThickness="1"/>
          <Button Name="ExportButton"
                  Content="⬇️ 导出"
                  Height="36"
                  Padding="16,0"
                  CornerRadius="6"
                  Background="#238636"/>
        </StackPanel>
      </Grid>
    </Border>
    
  </Grid>
</UserControl>
