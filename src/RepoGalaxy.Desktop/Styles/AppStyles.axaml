<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- 全局颜色定义 -->
    <Styles.Resources>
        <!-- 星空背景色 -->
        <Color x:Key="StarfieldBackgroundColor">#0B0E14</Color>
        <Color x:Key="StarfieldAccentColor">#58A6FF</Color>
        
        <!-- 画刷 -->
        <SolidColorBrush x:Key="StarfieldBackgroundBrush" Color="{StaticResource StarfieldBackgroundColor}" />
        <SolidColorBrush x:Key="StarfieldAccentBrush" Color="{StaticResource StarfieldAccentColor}" />
        
        <!-- 卡片背景 -->
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#161B22" Opacity="0.8" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#30363D" />
    </Styles.Resources>
    
    <!-- 窗口背景 -->
    <Style Selector="Window">
        <Setter Property="Background" Value="{StaticResource StarfieldBackgroundBrush}" />
    </Style>
    
    <!-- TabControl 样式 -->
    <Style Selector="TabControl">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    
    <!-- TabItem 样式 -->
    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="16,8" />
    </Style>
    
    <!-- 按钮样式 -->
    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="4" />
    </Style>
    
    <!-- 文本框样式 -->
    <Style Selector="TextBox">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="#21262D" />
        <Setter Property="BorderBrush" Value="#30363D" />
    </Style>
    
    <!-- 滚动条样式 -->
    <Style Selector="ScrollViewer">
        <Setter Property="Margin" Value="0" />
    </Style>
    
    <!-- 导航按钮样式 -->
    <Style Selector="Button.NavButton">
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    
    <Style Selector="Button.NavButton:pointerover">
        <Setter Property="Background" Value="#21262D" />
    </Style>
    
    <Style Selector="Button.NavButton:pressed">
        <Setter Property="Background" Value="#30363D" />
    </Style>
    
    <!-- 卡片样式 -->
    <Style Selector="Border.Card">
        <Setter Property="Background" Value="#161B22" />
        <Setter Property="BorderBrush" Value="#30363D" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BoxShadow" Value="0 2 4 0 #00000020" />
    </Style>
    
    <Style Selector="Border.Card:pointerover">
        <Setter Property="Background" Value="#1C2128" />
        <Setter Property="BorderBrush" Value="#58A6FF" />
    </Style>
    
</Styles>
