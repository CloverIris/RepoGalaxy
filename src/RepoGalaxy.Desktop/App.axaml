<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:RepoGalaxy.Desktop"
             xmlns:converters="using:RepoGalaxy.Desktop.Converters"
             x:Class="RepoGalaxy.Desktop.App"
             RequestedThemeVariant="Default">
  <Application.Resources>
    <ResourceDictionary>
      <converters:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="CanvasBrush" Color="#F6F8FB"/>
          <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F0F4F8"/>
          <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#FFFFFF"/>
          <SolidColorBrush x:Key="BorderBrush" Color="#DCE3EC"/>
          <SolidColorBrush x:Key="BorderStrongBrush" Color="#C7D1DE"/>
          <SolidColorBrush x:Key="PrimaryTextBrush" Color="#172033"/>
          <SolidColorBrush x:Key="SecondaryTextBrush" Color="#667085"/>
          <SolidColorBrush x:Key="TertiaryTextBrush" Color="#8B98AA"/>
          <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>
          <SolidColorBrush x:Key="AccentHoverBrush" Color="#2563EB"/>
          <SolidColorBrush x:Key="AccentSoftBrush" Color="#EAF3FF"/>
          <SolidColorBrush x:Key="AccentTextBrush" Color="#1D5FBF"/>
          <SolidColorBrush x:Key="SuccessBrush" Color="#16865C"/>
          <SolidColorBrush x:Key="SuccessSoftBrush" Color="#E8F7F0"/>
          <SolidColorBrush x:Key="WarningBrush" Color="#A65D08"/>
          <SolidColorBrush x:Key="WarningSoftBrush" Color="#FFF4DE"/>
          <SolidColorBrush x:Key="DangerBrush" Color="#D33B45"/>
          <SolidColorBrush x:Key="DangerSoftBrush" Color="#FDECEF"/>
          <SolidColorBrush x:Key="OverlayBrush" Color="#520B1220"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="CanvasBrush" Color="#0E1117"/>
          <SolidColorBrush x:Key="SurfaceBrush" Color="#151A22"/>
          <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#1B222D"/>
          <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#202733"/>
          <SolidColorBrush x:Key="BorderBrush" Color="#293241"/>
          <SolidColorBrush x:Key="BorderStrongBrush" Color="#3A4557"/>
          <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F2F5F9"/>
          <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A9B4C4"/>
          <SolidColorBrush x:Key="TertiaryTextBrush" Color="#78869A"/>
          <SolidColorBrush x:Key="AccentBrush" Color="#60A5FA"/>
          <SolidColorBrush x:Key="AccentHoverBrush" Color="#84BCFF"/>
          <SolidColorBrush x:Key="AccentSoftBrush" Color="#172A44"/>
          <SolidColorBrush x:Key="AccentTextBrush" Color="#9CCBFF"/>
          <SolidColorBrush x:Key="SuccessBrush" Color="#57C997"/>
          <SolidColorBrush x:Key="SuccessSoftBrush" Color="#17362C"/>
          <SolidColorBrush x:Key="WarningBrush" Color="#F5B95B"/>
          <SolidColorBrush x:Key="WarningSoftBrush" Color="#3B2D16"/>
          <SolidColorBrush x:Key="DangerBrush" Color="#FF7B86"/>
          <SolidColorBrush x:Key="DangerSoftBrush" Color="#412129"/>
          <SolidColorBrush x:Key="OverlayBrush" Color="#A6000000"/>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <StreamGeometry x:Key="IconDiscover">M3,5 L9,3 L7,9 L5,10 L3,16 L9,14 L11,8 L16,6 L14,12 L8,14</StreamGeometry>
      <StreamGeometry x:Key="IconSubscription">M4,3 L16,3 L16,15 L11,12 L6,15 L6,5 L4,5 Z</StreamGeometry>
      <StreamGeometry x:Key="IconLibrary">M3,4 L9,4 L11,6 L17,6 L17,16 L3,16 Z</StreamGeometry>
      <StreamGeometry x:Key="IconNotification">M10,2 C7,2 5,4 5,7 L5,11 L3,14 L17,14 L15,11 L15,7 C15,4 13,2 10,2 M8,16 L12,16 C12,18 8,18 8,16</StreamGeometry>
      <StreamGeometry x:Key="IconCloudRepo">M4,5 L8,5 L10,7 L16,7 L16,15 L4,15 Z M7,9 L13,9 M7,12 L11,12</StreamGeometry>
      <StreamGeometry x:Key="IconLocalRepo">M3,4 L17,4 L17,15 L3,15 Z M6,8 L8,10 L6,12 M10,12 L14,12</StreamGeometry>
      <StreamGeometry x:Key="IconSettings">M10,2 L12,3 L14,2 L16,4 L15,6 L16,8 L18,9 L18,11 L16,12 L15,14 L16,16 L14,18 L12,17 L10,18 L8,17 L6,18 L4,16 L5,14 L4,12 L2,11 L2,9 L4,8 L5,6 L4,4 L6,2 L8,3 Z M10,7 A3,3 0 1 0 10,13 A3,3 0 1 0 10,7</StreamGeometry>
      <StreamGeometry x:Key="IconSearch">M8,3 A5,5 0 1 0 8,13 A5,5 0 1 0 8,3 M12,12 L17,17</StreamGeometry>
      <StreamGeometry x:Key="IconRefresh">M15,6 L15,2 L18,5 L15,8 L15,6 C13,3 8,2 5,5 C2,8 3,13 6,15 M5,14 L5,18 L2,15 L5,12 L5,14 C7,17 12,18 15,15 C18,12 17,8 15,6</StreamGeometry>
      <StreamGeometry x:Key="IconChevronLeft">M12,4 L6,10 L12,16</StreamGeometry>
      <StreamGeometry x:Key="IconChevronRight">M8,4 L14,10 L8,16</StreamGeometry>
      <StreamGeometry x:Key="IconExternal">M10,4 L16,4 L16,10 M16,4 L9,11 M14,12 L14,16 L4,16 L4,6 L8,6</StreamGeometry>
      <StreamGeometry x:Key="IconBookmark">M5,3 L15,3 L15,17 L10,13 L5,17 Z</StreamGeometry>
      <StreamGeometry x:Key="IconClose">M5,5 L15,15 M15,5 L5,15</StreamGeometry>
      <StreamGeometry x:Key="IconLink">M8,12 L12,8 M7,14 L5,16 C3,18 0,15 2,13 L5,10 C6,9 8,9 9,10 M11,10 C12,11 14,11 15,10 L18,7 C20,5 17,2 15,4 L13,6</StreamGeometry>
      <StreamGeometry x:Key="IconMore">M5,10 A1,1 0 1 0 5,10.1 M10,10 A1,1 0 1 0 10,10.1 M15,10 A1,1 0 1 0 15,10.1</StreamGeometry>
      <StreamGeometry x:Key="IconCode">M7,5 L2,10 L7,15 M13,5 L18,10 L13,15 M12,3 L8,17</StreamGeometry>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window">
      <Setter Property="FontFamily" Value="Microsoft YaHei UI, Inter, Segoe UI"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="Background" Value="{DynamicResource CanvasBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
    </Style>
    <Style Selector="UserControl">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="27"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
    </Style>
    <Style Selector="TextBlock.h2">
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
    </Style>
    <Style Selector="TextBlock.meta">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
    <Style Selector="Border.soft-card">
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="14"/>
    </Style>
    <Style Selector="Border.badge">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="8,3"/>
    </Style>
    <Style Selector="Border.badge TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Padding" Value="14,7"/>
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.primary:pointerover">
      <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
    </Style>
    <Style Selector="Button.subtle">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="Button.ghost">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.icon">
      <Setter Property="Width" Value="36"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
      <Setter Property="Background" Value="{DynamicResource DangerSoftBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="Button.caption-close">
      <Setter Property="Width" Value="46"/>
      <Setter Property="Height" Value="42"/>
      <Setter Property="MinHeight" Value="42"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.caption-close:pointerover">
      <Setter Property="Background" Value="#E81123"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="TextBox.search">
      <Setter Property="MinHeight" Value="38"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="Padding" Value="12,8"/>
    </Style>
    <Style Selector="TextBox, ComboBox, NumericUpDown">
      <Setter Property="MinHeight" Value="38"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="ListBox.clean">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="ListBox.clean > ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="ListBox.clean > ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Separator">
      <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
    </Style>
    <Style Selector="ProgressBar">
      <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
    </Style>
  </Application.Styles>

  <Application.DataTemplates>
    <local:ViewLocator />
  </Application.DataTemplates>
</Application>
