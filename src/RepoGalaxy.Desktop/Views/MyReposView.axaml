<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:RepoGalaxy.Desktop.ViewModels" x:Class="RepoGalaxy.Desktop.Views.MyReposView" x:DataType="vm:MyReposViewModel"><Grid Margin="24" RowDefinitions="Auto,*"><Grid ColumnDefinitions="*,Auto"><TextBlock Text="我的仓库" FontSize="28" FontWeight="SemiBold"/><Button Grid.Column="1" Content="刷新" Command="{Binding RefreshCommand}"/></Grid><ListBox Grid.Row="1" ItemsSource="{Binding Repositories}" Margin="0,16,0,0"><ListBox.ItemTemplate><DataTemplate><StackPanel Margin="12" Spacing="4"><TextBlock Text="{Binding FullName}" FontWeight="SemiBold"/><TextBlock Text="{Binding Description}" Opacity="0.7"/><TextBlock Text="{Binding StarsFormatted, StringFormat='★ {0}'}" FontSize="12"/></StackPanel></DataTemplate></ListBox.ItemTemplate></ListBox></Grid></UserControl>
