<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="RepoGalaxy.Desktop.Views.SubscriptionsView" x:CompileBindings="False"><Grid Margin="24" RowDefinitions="Auto,*"><Border Padding="16"><Grid ColumnDefinitions="160,*,*,*,Auto" ColumnSpacing="10"><TextBox Text="{Binding Name}" PlaceholderText="Subscription name"/><TextBox Grid.Column="1" Text="{Binding Topics}" PlaceholderText="Topics, comma separated"/><TextBox Grid.Column="2" Text="{Binding Languages}" PlaceholderText="Languages, comma separated"/><TextBox Grid.Column="3" Text="{Binding Keywords}" PlaceholderText="Keywords, comma separated"/><Button Grid.Column="4" Content="Add subscription" Command="{Binding AddCommand}"/></Grid></Border><ListBox Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,16,0,0"><ListBox.ItemTemplate><DataTemplate><Grid ColumnDefinitions="*,Auto" Margin="12"><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Topics}" Opacity="0.65"/></StackPanel><Button Grid.Column="1" Content="Delete" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Id}"/></Grid></DataTemplate></ListBox.ItemTemplate></ListBox></Grid></UserControl>
