<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RepoGalaxy.Desktop.ViewModels.Dialogs"
        xmlns:controls="using:RepoGalaxy.Desktop.Controls"
        x:Class="RepoGalaxy.Desktop.Views.Dialogs.LoginDialog"
        x:DataType="vm:LoginDialogViewModel"
        Title="连接 GitHub"
        Icon="/Assets/repogalaxy.ico"
        Width="520" Height="620"
        MinWidth="460" MinHeight="560"
        CanResize="False"
        WindowDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="42"
        Win32Properties.WindowCornerPreference="DoNotRound"
        WindowStartupLocation="CenterOwner">
  <Grid Background="{DynamicResource CanvasBrush}" RowDefinitions="42,*">
    <Border x:Name="LoginTitleBar" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,46">
        <controls:RepoGalaxyMark x:Name="LoginBrandMark" Width="20" Height="20" Margin="14,0,9,0"/>
        <TextBlock Grid.Column="1" Text="连接 GitHub" VerticalAlignment="Center" FontWeight="SemiBold"/>
        <Button x:Name="LoginCloseButton" Grid.Column="2" Width="46" Height="42" Padding="0" Classes="caption-close" Click="OnCloseClicked"><Grid Width="20" Height="20"><Path Data="M3,3 L17,17 M17,3 L3,17" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid></Button>
      </Grid>
    </Border>
    <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Margin="18" CornerRadius="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="30">
      <Grid RowDefinitions="Auto,*,Auto">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
          <controls:RepoGalaxyMark Width="46" Height="46"/>
          <StackPanel Grid.Column="1" Spacing="4"><TextBlock Text="连接 GitHub" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="登录后获得完整发现 Feed 与持续同步。" Classes="muted"/></StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,28,0,18">
          <StackPanel IsVisible="{Binding CurrentState, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Idle}" Spacing="13">
            <Button Command="{Binding StartDeviceLoginCommand}" HorizontalAlignment="Stretch" Padding="18" Classes="primary">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14"><Border Width="38" Height="38" CornerRadius="0" Background="#28FFFFFF"><TextBlock Text="01" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Grid.Column="1" Spacing="4"><TextBlock Text="使用设备码登录" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="推荐方式 · 在浏览器确认，无需在应用内输入密码" Foreground="#E8F2FF" FontSize="12"/></StackPanel></Grid>
            </Button>
            <Button Command="{Binding StartBrowserLoginCommand}" IsVisible="{Binding CanUseBrowserLogin}" HorizontalAlignment="Stretch" Padding="18" Classes="subtle">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14"><Border Width="38" Height="38" CornerRadius="0" Background="{DynamicResource AccentSoftBrush}"><PathIcon Data="{StaticResource IconExternal}" Width="18" Height="18" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Grid.Column="1" Spacing="4"><TextBlock Text="浏览器本地回环" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="仅在本机安全配置 OAuth Secret 后可用" Classes="meta"/></StackPanel></Grid>
            </Button>
            <Expander Header="使用 Personal Access Token" Margin="0,4,0,0">
              <StackPanel Margin="0,12,0,0" Spacing="9"><TextBox Text="{Binding PatToken}" PlaceholderText="github_pat_…" PasswordChar="●"/><Button Content="验证并登录" Command="{Binding LoginWithPatCommand}" Classes="subtle" HorizontalAlignment="Right"/></StackPanel>
            </Expander>
            <Border Classes="soft-card" Margin="0,8,0,0"><TextBlock Text="凭证仅使用当前 Windows 用户的 DPAPI 加密保存，RepoGalaxy 不会记录或显示 Token。" Classes="meta" TextWrapping="Wrap" LineHeight="19"/></Border>
          </StackPanel>

          <StackPanel IsVisible="{Binding CurrentState, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=DeviceCode}" Spacing="18" VerticalAlignment="Center">
            <TextBlock Text="在浏览器中确认授权" FontSize="21" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="复制下面的设备码，然后前往 GitHub 授权页面。" Classes="muted" HorizontalAlignment="Center"/>
            <Border Classes="soft-card" Padding="22"><TextBlock Text="{Binding UserCodeDisplay}" FontSize="36" FontWeight="Bold" LetterSpacing="3" Foreground="{DynamicResource AccentTextBrush}" HorizontalAlignment="Center"/></Border>
            <Button Content="打开 GitHub 授权页面" Command="{Binding OpenVerificationPageCommand}" Classes="primary" HorizontalAlignment="Stretch"/>
            <TextBlock Text="{Binding StatusText}" Classes="meta" HorizontalAlignment="Center" TextWrapping="Wrap"/>
          </StackPanel>

          <StackPanel IsVisible="{Binding CurrentState, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Polling}" Spacing="18" VerticalAlignment="Center">
            <Border Width="58" Height="58" CornerRadius="29" Background="{DynamicResource AccentSoftBrush}"><ProgressBar IsIndeterminate="True" Width="34" Height="4" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
            <TextBlock Text="正在等待 GitHub" FontSize="21" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding StatusText}" Classes="muted" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
          </StackPanel>

          <StackPanel IsVisible="{Binding CurrentState, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Success}" Spacing="14" VerticalAlignment="Center">
            <Border Width="62" Height="62" CornerRadius="31" Background="{DynamicResource SuccessSoftBrush}"><TextBlock Text="✓" FontSize="28" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
            <TextBlock Text="登录成功" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="凭证已安全保存，正在返回 RepoGalaxy。" Classes="muted" HorizontalAlignment="Center"/>
          </StackPanel>

          <StackPanel IsVisible="{Binding CurrentState, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Error}" Spacing="14" VerticalAlignment="Center">
            <Border Width="62" Height="62" CornerRadius="31" Background="{DynamicResource DangerSoftBrush}"><TextBlock Text="!" FontSize="28" Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
            <TextBlock Text="登录没有完成" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding ErrorText}" Classes="muted" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" MaxWidth="360"/>
            <Button Content="重新尝试" Command="{Binding RetryCommand}" Classes="primary" HorizontalAlignment="Center"/>
          </StackPanel>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto"><TextBlock Text="不会新增 GitHub OAuth 权限" Classes="meta" VerticalAlignment="Center"/><Button Grid.Column="1" Content="取消" Classes="ghost" Command="{Binding CancelCommand}"/></Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
