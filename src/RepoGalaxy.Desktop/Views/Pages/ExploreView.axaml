<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RepoGalaxy.Desktop.ViewModels"
             xmlns:ctrl="using:RepoGalaxy.Desktop.Controls"
             x:Class="RepoGalaxy.Desktop.Views.Pages.ExploreView"
             x:DataType="vm:ExploreViewModel"
             Background="Transparent">

  <Grid RowDefinitions="Auto,*">
    
    <!-- 顶部控制栏 -->
    <Border Grid.Row="0" 
            Background="#161B22" 
            BorderBrush="#30363D"
            BorderThickness="0,0,0,1"
            Padding="16,12">
      <Grid ColumnDefinitions="Auto,*,Auto">
        
        <!-- 标题 -->
        <TextBlock Grid.Column="0"
                   Text="🌌 探索"
                   FontSize="20"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="0,0,24,0"/>
        
        <!-- 筛选 Pill 栏 -->
        <StackPanel Grid.Column="1" 
                    Orientation="Horizontal" 
                    Spacing="12"
                    VerticalAlignment="Center">
          <ComboBox SelectedItem="{Binding SelectedLanguage}"
                    ItemsSource="{Binding LanguageOptions}"
                    Width="100"
                    CornerRadius="16"
                    Background="#0D1117"
                    BorderBrush="#30363D"/>
          
          <ComboBox SelectedItem="{Binding SelectedSort}"
                    ItemsSource="{Binding SortOptions}"
                    Width="100"
                    CornerRadius="16"
                    Background="#0D1117"
                    BorderBrush="#30363D"/>
        </StackPanel>
        
        <!-- 刷新按钮 -->
        <Button Grid.Column="2"
                Content="🔄"
                Command="{Binding RefreshCommand}"
                IsEnabled="{Binding !IsLoading}"
                Background="Transparent"
                BorderBrush="#30363D"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,4"/>
      </Grid>
    </Border>

    <!-- 气泡云可视化区域 -->
    <Grid Grid.Row="1">
      <!-- 气泡云控件 -->
      <ctrl:BubbleCloudControl x:Name="BubbleCloud"
                               Items="{Binding BubbleItems}"
                               SelectedItem="{Binding SelectedBubble, Mode=TwoWay}"/>
      
      <!-- 加载状态 -->
      <ProgressBar IsVisible="{Binding IsLoading}"
                   IsIndeterminate="True"
                   Height="4"
                   VerticalAlignment="Top"
                   Margin="0,-2,0,0"/>
      
      <!-- 空状态 -->
      <Border IsVisible="{Binding ShowEmptyState}"
              Background="#161B22"
              BorderBrush="#30363D"
              BorderThickness="1"
              CornerRadius="12"
              Padding="48"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="12" HorizontalAlignment="Center">
          <TextBlock Text="🔭" 
                     FontSize="64" 
                     HorizontalAlignment="Center"/>
          <TextBlock Text="这片星空很安静"
                     FontSize="20"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="{Binding StatusMessage}"
                     Opacity="0.7"
                     HorizontalAlignment="Center"/>
          <Button Content="从 GitHub 同步数据"
                  Command="{Binding RefreshCommand}"
                  Background="#238636"
                  Foreground="White"
                  CornerRadius="4"
                  Padding="16,8"
                  HorizontalAlignment="Center"
                  Margin="0,12,0,0"/>
        </StackPanel>
      </Border>
      
      <!-- 状态信息 -->
      <TextBlock Text="{Binding StatusMessage}"
                 VerticalAlignment="Bottom"
                 HorizontalAlignment="Left"
                 Margin="16"
                 Opacity="0.6"
                 FontSize="12"/>
    </Grid>
  </Grid>
</UserControl>
