<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RepoGalaxy.Desktop.Controls"
             xmlns:views="clr-namespace:RepoGalaxy.Desktop.Views"
             x:Class="RepoGalaxy.Desktop.Views.DiscoverView"
             x:CompileBindings="False">
  <UserControl.Styles>
    <Style Selector="Button.segment">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.segment.selected">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" Background="{DynamicResource CanvasBrush}">
    <Border Padding="20,10" Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
        <Border Background="{DynamicResource SurfaceMutedBrush}" Padding="2">
          <ItemsControl ItemsSource="{Binding Sources}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Classes="segment" Classes.selected="{Binding IsSelected}"
                        Command="{Binding DataContext.SelectSourceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}">
                  <StackPanel Orientation="Horizontal" Spacing="7">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Count}" Opacity=".72"/>
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBlock Text="二维 Tile 世界" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource AccentTextBrush}"/>
          <TextBlock Text="{Binding ResultSummary}" Classes="meta"/>
          <TextBlock Text="{Binding TilePopulationSummary}" Classes="meta"/>
          <TextBlock Text="{Binding SpatialSearchStatus}" Classes="meta"/>
          <Border IsVisible="{Binding HasActiveTileFilter}" Background="{DynamicResource AccentBrush}" Padding="8,3">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <TextBlock Text="{Binding ActiveTileFilter}" Foreground="White"/>
              <Button Classes="ghost" Content="×" Foreground="White" Padding="2,0" MinHeight="20"
                      Command="{Binding ClearTileFilterCommand}"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
          <Border Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1" Padding="9,6">
            <TextBlock Text="{Binding ZoomText}" FontWeight="SemiBold"/>
          </Border>
          <Button Classes="subtle" Content="回到中景" ToolTip.Tip="恢复 100% 视图 (Home)"
                  Command="{Binding ReturnToMiddleCommand}"/>
          <Button Classes="subtle" Content="查看索引" ToolTip.Tip="缩放到语言与框架索引"
                  Command="{Binding ShowSemanticIndexCommand}"/>
          <Button Classes="primary" Command="{Binding SyncCommand}">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <PathIcon Data="{StaticResource IconRefresh}" Width="15" Height="15"/>
              <TextBlock Text="同步"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" x:Name="WorldHost" ClipToBounds="True" Background="{DynamicResource CanvasBrush}">
      <Canvas ZIndex="{Binding PortalZIndex}" IsVisible="{Binding IsPortalVisible}"
              IsHitTestVisible="{Binding IsDetailInteractive}">
        <Border Canvas.Left="{Binding PortalX}" Canvas.Top="{Binding PortalY}"
                Width="{Binding PortalWidth}" Height="{Binding PortalHeight}"
                ClipToBounds="True" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                Background="{DynamicResource CanvasBrush}">
          <views:ImmersiveDetailSurface Width="{Binding DetailViewportWidth}" Height="{Binding DetailViewportHeight}"
                                        Opacity="{Binding PortalContentOpacity}"
                                        HorizontalAlignment="Left" VerticalAlignment="Top">
            <views:ImmersiveDetailSurface.RenderTransform>
              <TranslateTransform X="{Binding PortalInnerOffsetX}" Y="{Binding PortalInnerOffsetY}"/>
            </views:ImmersiveDetailSurface.RenderTransform>
          </views:ImmersiveDetailSurface>
        </Border>
      </Canvas>

      <controls:VirtualizedTileWorldControl x:Name="TileWorld"
                                           ZIndex="{Binding TileWorldZIndex}"
                                           CameraX="{Binding CameraX}"
                                           CameraY="{Binding CameraY}"
                                           Zoom="{Binding Zoom}"
                                           SkeletonRevision="{Binding SkeletonRevision}"
                                           Opacity="{Binding TileBoardOpacity}"/>

      <views:SemanticIndexView ZIndex="30" Opacity="{Binding SemanticIndexOpacity}"/>
      <ProgressBar ZIndex="40" IsIndeterminate="True" IsVisible="{Binding IsLoading}"
                   Height="3" VerticalAlignment="Top"/>
      <Popup ZIndex="60"
             IsOpen="{Binding IsDislikeMenuOpen, Mode=TwoWay}"
             PlacementTarget="{Binding #TileWorld}"
             Placement="Pointer"
             IsLightDismissEnabled="True">
        <Border Width="220"
                Padding="8"
                Background="{DynamicResource ElevatedSurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
          <StackPanel Spacing="4">
            <TextBlock Margin="8,4,8,6"
                       Text="减少类似推荐"
                       FontWeight="SemiBold"/>
            <Button Classes="subtle"
                    HorizontalContentAlignment="Left"
                    Content="少推荐这一类"
                    Command="{Binding SuppressDislikeCategoryCommand}"/>
            <Button Classes="subtle"
                    HorizontalContentAlignment="Left"
                    Content="不感兴趣这个"
                    Command="{Binding DismissDislikeTargetCommand}"/>
          </StackPanel>
        </Border>
      </Popup>
    </Grid>
  </Grid>
</UserControl>
