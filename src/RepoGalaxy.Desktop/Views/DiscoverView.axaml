<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RepoGalaxy.Desktop.ViewModels"
             x:Class="RepoGalaxy.Desktop.Views.DiscoverView"
             x:CompileBindings="False">
  <UserControl.Styles>
    <Style Selector="Button.segment">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
      <Setter Property="Padding" Value="14,8"/>
    </Style>
    <Style Selector="Button.segment.selected">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
    </Style>
    <Style Selector="Border.feed-row">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="11"/>
      <Setter Property="Padding" Value="18,15"/>
      <Setter Property="Margin" Value="0,0,0,9"/>
    </Style>
    <Style Selector="ListBoxItem:selected Border.feed-row">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
    </Style>
  </UserControl.Styles>

  <Grid Margin="28,22,28,26" RowDefinitions="Auto,Auto,*">
    <Grid ColumnDefinitions="*,Auto">
      <StackPanel Spacing="5">
        <TextBlock Text="值得投入时间的新项目" Classes="h1"/>
        <TextBlock Text="从 GitHub 的噪声中筛出真正有价值、值得持续关注的代码。" Classes="muted"/>
      </StackPanel>
      <Button Grid.Column="1" Classes="primary" Command="{Binding SyncCommand}" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="8"><PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16"/><TextBlock Text="立即同步"/></StackPanel>
      </Button>
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="Auto,*" Margin="0,22,0,15">
      <Border Background="{DynamicResource SurfaceMutedBrush}" CornerRadius="10" Padding="4">
        <ItemsControl ItemsSource="{Binding Sources}">
          <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="2"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Classes="segment" Classes.selected="{Binding IsSelected}"
                      Command="{Binding DataContext.SelectSourceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                <StackPanel Orientation="Horizontal" Spacing="7"><TextBlock Text="{Binding Title}" FontWeight="SemiBold"/><TextBlock Text="{Binding Count}" Classes="meta"/></StackPanel>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>
      <TextBlock Grid.Column="1" Text="{Binding ResultSummary}" Classes="meta" HorizontalAlignment="Right" VerticalAlignment="Center"/>
    </Grid>

    <Grid Grid.Row="2">
      <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="3" VerticalAlignment="Top"/>

      <ListBox Classes="clean" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" IsVisible="{Binding HasItems}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Classes="feed-row">
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                <StackPanel Orientation="Horizontal" Spacing="9">
                  <Border Width="28" Height="28" CornerRadius="8" Background="{DynamicResource AccentSoftBrush}">
                    <TextBlock Text="&lt;/&gt;" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <TextBlock Text="{Binding Repository.FullName}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <Border Classes="badge" VerticalAlignment="Center"><TextBlock Text="{Binding SourceText}"/></Border>
                  <Ellipse Width="5" Height="5" Fill="{DynamicResource AccentBrush}" IsVisible="{Binding IsUnread}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                  <Button Classes="ghost" Content="{Binding SaveText}"
                          Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Id}"/>
                  <Button Classes="icon" Command="{Binding DataContext.DismissCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Id}" ToolTip.Tip="忽略">
                    <PathIcon Data="{StaticResource IconClose}" Width="15" Height="15"/>
                  </Button>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Repository.Description}" Classes="muted" MaxLines="2" TextTrimming="CharacterEllipsis" LineHeight="20" Margin="37,0,50,0"/>

                <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="37,0,0,0">
                  <StackPanel Orientation="Horizontal" Spacing="14">
                    <TextBlock Text="{Binding Repository.PrimaryLanguage}" Classes="meta" Foreground="{DynamicResource AccentTextBrush}"/>
                    <TextBlock Text="{Binding Repository.StarsFormatted, StringFormat='★ {0}'}" Classes="meta"/>
                    <TextBlock Text="{Binding Repository.ForksFormatted, StringFormat='Fork {0}'}" Classes="meta"/>
                    <TextBlock Text="{Binding DiscoveredText}" Classes="meta"/>
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding ReasonText}" Classes="meta" TextTrimming="CharacterEllipsis" MaxWidth="330"/>
                </Grid>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Border IsVisible="{Binding IsEmpty}" Classes="card" MaxWidth="720" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="38">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="28">
          <Border Width="78" Height="78" CornerRadius="22" Background="{DynamicResource AccentSoftBrush}">
            <PathIcon Data="{StaticResource IconDiscover}" Width="34" Height="34" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <StackPanel Grid.Column="1" Spacing="13">
            <StackPanel Spacing="5">
              <TextBlock Text="{Binding StatusTitle}" FontSize="21" FontWeight="SemiBold"/>
              <TextBlock Text="{Binding StatusDescription}" Classes="muted" TextWrapping="Wrap" LineHeight="21"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="9">
              <Button Classes="primary" Content="立即发现" Command="{Binding SyncCommand}"/>
              <Button Classes="subtle" Content="登录 GitHub" Command="{Binding RequestLoginCommand}"/>
            </StackPanel>
            <StackPanel Spacing="7">
              <TextBlock Text="或者从一个方向开始" Classes="meta"/>
              <ItemsControl ItemsSource="{Binding SuggestedTopics}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel ItemSpacing="7" LineSpacing="7"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate><DataTemplate><Button Classes="ghost" Background="{DynamicResource SurfaceMutedBrush}" Content="{Binding}" Command="{Binding DataContext.CreateSubscriptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/></DataTemplate></ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>
