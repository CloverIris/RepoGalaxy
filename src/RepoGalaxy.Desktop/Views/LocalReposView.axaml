<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:RepoGalaxy.Desktop.ViewModels" x:Class="RepoGalaxy.Desktop.Views.LocalReposView" x:DataType="vm:LocalReposViewModel"><Grid Margin="24" RowDefinitions="Auto,Auto,*"><TextBlock Text="本地仓库" FontSize="28" FontWeight="SemiBold"/><Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,16"><TextBox Text="{Binding ScanPath}" PlaceholderText="输入要扫描的文件夹"/><Button Grid.Column="1" Content="扫描" Command="{Binding ScanCommand}"/></Grid><ListBox Grid.Row="2" ItemsSource="{Binding LocalRepositories}"><ListBox.ItemTemplate><DataTemplate><StackPanel Margin="12"><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding LocalPath}" Opacity="0.7"/></StackPanel></DataTemplate></ListBox.ItemTemplate></ListBox></Grid></UserControl>
