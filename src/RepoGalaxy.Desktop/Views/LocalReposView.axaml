<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="RepoGalaxy.Desktop.Views.LocalReposView" x:CompileBindings="False">
  <Grid Margin="28,22,28,26" RowDefinitions="Auto,Auto,*">
    <StackPanel Spacing="5"><TextBlock Text="本地仓库" Classes="h1"/><TextBlock Text="扫描常用工作目录，把本地代码和 GitHub 发现分开管理。" Classes="muted"/></StackPanel>
    <Border Grid.Row="1" Classes="card" Margin="0,20,0,14"><Grid RowDefinitions="Auto,Auto" RowSpacing="10"><Grid ColumnDefinitions="*,Auto" ColumnSpacing="10"><TextBox Text="{Binding ScanPath}" PlaceholderText="输入需要扫描的工作目录"/><Button Grid.Column="1" Classes="primary" Content="扫描目录" Command="{Binding ScanCommand}" MinWidth="110"/></Grid><Grid Grid.Row="1" ColumnDefinitions="*,Auto"><TextBlock Text="只识别包含 .git 的目录，不会修改仓库内容。" Classes="meta"/><TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Classes="meta" Foreground="{DynamicResource AccentTextBrush}"/></Grid></Grid></Border>
    <Grid Grid.Row="2">
      <ProgressBar Height="3" IsIndeterminate="True" IsVisible="{Binding IsLoading}" VerticalAlignment="Top"/>
      <ListBox Classes="clean" ItemsSource="{Binding LocalRepositories}">
        <ListBox.ItemTemplate><DataTemplate><Border Classes="card" Margin="0,0,0,9" Padding="18,14"><Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14"><Border Width="42" Height="42" CornerRadius="11" Background="{DynamicResource AccentSoftBrush}"><PathIcon Data="{StaticResource IconLocalRepo}" Width="20" Height="20" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Grid.Column="1" Spacing="5"><TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="{Binding LocalPath}" Classes="muted" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding AddedText}" Classes="meta"/></StackPanel><StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"><Button Classes="subtle" Content="打开" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/><Button Classes="ghost" Content="复制路径" Command="{Binding DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/><Button Classes="danger" Content="移除" Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Id}"/></StackPanel></Grid></Border></DataTemplate></ListBox.ItemTemplate>
      </ListBox>
      <Border IsVisible="{Binding IsEmpty}" Classes="card" MaxWidth="570" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="34"><StackPanel Spacing="10" HorizontalAlignment="Center"><PathIcon Data="{StaticResource IconLocalRepo}" Width="32" Height="32" Foreground="{DynamicResource AccentBrush}"/><TextBlock Text="还没有收录本地仓库" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="确认上方目录后开始扫描，仓库只会记录在本地。" Classes="muted"/></StackPanel></Border>
    </Grid>
  </Grid>
</UserControl>
