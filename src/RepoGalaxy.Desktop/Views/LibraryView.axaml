<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="RepoGalaxy.Desktop.Views.LibraryView" x:CompileBindings="False">
  <Grid Margin="28,22,28,26" RowDefinitions="Auto,Auto,*">
    <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="5"><TextBlock Text="收藏库" Classes="h1"/><TextBlock Text="把值得评估、阅读或采用的仓库保存在一个安静的工作区。" Classes="muted"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding Status}" Classes="meta" VerticalAlignment="Bottom"/></Grid>
    <Border Grid.Row="1" Classes="soft-card" Margin="0,20,0,14">
      <Grid ColumnDefinitions="*,180,180" ColumnSpacing="10"><TextBlock Text="搜索由顶部全局搜索框完成" Classes="meta" VerticalAlignment="Center"/><ComboBox Grid.Column="1" ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}"/><ComboBox Grid.Column="2" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSort}"/></Grid>
    </Border>
    <Grid Grid.Row="2">
      <ProgressBar Height="3" IsIndeterminate="True" IsVisible="{Binding IsLoading}" VerticalAlignment="Top"/>
      <ListBox Classes="clean" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}">
        <ListBox.ItemTemplate><DataTemplate>
          <Border Classes="card" Margin="0,0,0,9" Padding="18,15">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
              <Border Width="42" Height="42" CornerRadius="11" Background="{DynamicResource AccentSoftBrush}"><TextBlock Text="&lt;/&gt;" FontWeight="Bold" Foreground="{DynamicResource AccentTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
              <StackPanel Grid.Column="1" Spacing="6"><TextBlock Text="{Binding FullName}" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="{Binding Description}" Classes="muted" TextTrimming="CharacterEllipsis" MaxLines="1"/><StackPanel Orientation="Horizontal" Spacing="14"><TextBlock Text="{Binding PrimaryLanguage}" Classes="meta" Foreground="{DynamicResource AccentTextBrush}"/><TextBlock Text="{Binding StarsFormatted, StringFormat='★ {0}'}" Classes="meta"/><TextBlock Text="{Binding UpdatedText, StringFormat='更新 {0}'}" Classes="meta"/></StackPanel></StackPanel>
              <Button Grid.Column="2" Classes="danger" Content="移除" Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Id}" VerticalAlignment="Center"/>
            </Grid>
          </Border>
        </DataTemplate></ListBox.ItemTemplate>
      </ListBox>
      <Border IsVisible="{Binding IsEmpty}" Classes="card" MaxWidth="560" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="34"><StackPanel Spacing="10" HorizontalAlignment="Center"><PathIcon Data="{StaticResource IconLibrary}" Width="32" Height="32" Foreground="{DynamicResource AccentBrush}"/><TextBlock Text="收藏库还是空的" FontSize="20" FontWeight="SemiBold"/><TextBlock Text="在发现 Feed 中收藏仓库，它们会出现在这里。" Classes="muted"/></StackPanel></Border>
    </Grid>
  </Grid>
</UserControl>

