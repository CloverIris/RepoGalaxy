<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="RepoGalaxy.Desktop.Views.SettingsView" x:CompileBindings="False">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="28,22,28,32" Spacing="18" MaxWidth="760" HorizontalAlignment="Left">
      <StackPanel Spacing="5"><TextBlock Text="设置" Classes="h1"/><TextBlock Text="调整界面、同步频率和通知敏感度。更改会自动保存在本机。" Classes="muted"/></StackPanel>
      <Border Classes="card"><Grid ColumnDefinitions="*,220"><StackPanel Spacing="5"><TextBlock Text="外观" Classes="h2"/><TextBlock Text="默认跟随 Windows，你也可以固定为浅色或深色。" Classes="muted" TextWrapping="Wrap"/></StackPanel><ComboBox Grid.Column="1" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}" VerticalAlignment="Center"/></Grid></Border>
      <Border Classes="card"><Grid ColumnDefinitions="*,220"><StackPanel Spacing="5"><TextBlock Text="同步" Classes="h2"/><TextBlock Text="应用打开期间按所选间隔执行增量同步。" Classes="muted"/></StackPanel><ComboBox Grid.Column="1" ItemsSource="{Binding SyncIntervals}" SelectedItem="{Binding SyncIntervalMinutes}" VerticalAlignment="Center"/></Grid></Border>
      <Border Classes="card"><Grid RowDefinitions="Auto,Auto" RowSpacing="14"><Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="5"><TextBlock Text="通知阈值" Classes="h2"/><TextBlock Text="只让足够匹配的项目打断你。" Classes="muted"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding ThresholdText}" Foreground="{DynamicResource AccentTextBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/></Grid><Slider Grid.Row="1" Value="{Binding NotificationThreshold}" Minimum="0.5" Maximum="1" TickFrequency="0.05"/></Grid></Border>
      <Border Classes="card"><StackPanel Spacing="8"><TextBlock Text="账户与隐私" Classes="h2"/><TextBlock Text="GitHub 凭证仅使用当前 Windows 用户的 DPAPI 加密保存。游客模式每次启动只自动请求一次热门内容，其余时间使用本地缓存。" Classes="muted" TextWrapping="Wrap" LineHeight="21"/></StackPanel></Border>
      <TextBlock Text="{Binding SaveStatus}" Classes="meta" Foreground="{DynamicResource SuccessBrush}"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
