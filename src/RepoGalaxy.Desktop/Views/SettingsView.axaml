<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="RepoGalaxy.Desktop.Views.SettingsView" x:CompileBindings="False"><StackPanel Margin="24" Spacing="18" MaxWidth="520"><TextBlock Text="Settings" FontSize="28" FontWeight="SemiBold"/><StackPanel Spacing="4"><TextBlock Text="Theme"/><ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}" Width="180"/></StackPanel><StackPanel Spacing="4"><TextBlock Text="Sync interval (minutes)"/><NumericUpDown Value="{Binding SyncIntervalMinutes}" Minimum="15" Maximum="60" Increment="15"/></StackPanel><StackPanel Spacing="4"><TextBlock Text="New discovery notification threshold"/><Slider Value="{Binding NotificationThreshold}" Minimum="0" Maximum="1"/></StackPanel><TextBlock Text="Sync and notifications stop when the application closes." Opacity="0.65" TextWrapping="Wrap"/></StackPanel></UserControl>
