<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RepoGalaxy.Desktop.ViewModels"
        x:Class="RepoGalaxy.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="RepoGalaxy" Width="1360" Height="860" MinWidth="980" MinHeight="640">
  <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,*">
    <Border Grid.RowSpan="2" Padding="12" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}" BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Spacing="4" Margin="8,8,8,20"><TextBlock Text="RepoGalaxy" FontSize="22" FontWeight="SemiBold"/><TextBlock Text="GitHub discovery and subscriptions" Opacity="0.65" FontSize="12"/></StackPanel>
        <StackPanel Grid.Row="1" Spacing="4">
          <Button Content="Discover" Command="{Binding NavigateCommand}" CommandParameter="Discover" HorizontalContentAlignment="Left"/>
          <Button Content="Subscriptions" Command="{Binding NavigateCommand}" CommandParameter="Subscriptions" HorizontalContentAlignment="Left"/>
          <Button Content="Library" Command="{Binding NavigateCommand}" CommandParameter="Library" HorizontalContentAlignment="Left"/>
          <Button Content="Notifications" Command="{Binding NavigateCommand}" CommandParameter="Notifications" HorizontalContentAlignment="Left"/>
          <Separator Margin="0,8"/>
          <Button Content="My repositories" Command="{Binding NavigateCommand}" CommandParameter="MyRepos" HorizontalContentAlignment="Left"/>
          <Button Content="Local repositories" Command="{Binding NavigateCommand}" CommandParameter="LocalRepos" HorizontalContentAlignment="Left"/>
        </StackPanel>
        <Button Grid.Row="2" Content="Settings" Command="{Binding NavigateCommand}" CommandParameter="Settings" HorizontalContentAlignment="Left"/>
      </Grid>
    </Border>
    <Border Grid.Column="1" Padding="16,10" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12"><TextBlock Text="{Binding CurrentViewName}" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"><Button Content="Sync" Command="{Binding SyncCommand}"/><Button Content="Sign in to GitHub" Command="{Binding LoginCommand}" IsVisible="{Binding !IsAuthenticated}"/><TextBlock Text="{Binding CurrentUserLogin}" IsVisible="{Binding IsAuthenticated}" VerticalAlignment="Center"/><Button Content="Sign out" Command="{Binding LogoutCommand}" IsVisible="{Binding IsAuthenticated}"/></StackPanel></Grid>
    </Border>
    <Grid Grid.Row="1" Grid.Column="1"><ContentControl Content="{Binding CurrentView}"/><TextBlock Text="{Binding SyncStatus}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="16" Opacity="0.6" FontSize="12"/></Grid>
  </Grid>
</Window>
