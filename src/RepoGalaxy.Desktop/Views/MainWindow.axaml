<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RepoGalaxy.Desktop.ViewModels"
        xmlns:controls="using:RepoGalaxy.Desktop.Controls"
        x:Class="RepoGalaxy.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="RepoGalaxy"
        Width="1440" Height="900"
        MinWidth="900" MinHeight="640"
        CanResize="True"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="False"
        Win32Properties.WindowCornerPreference="DoNotRound">
  <Window.Styles>
    <Style Selector="Button.nav">
      <Setter Property="Height" Value="48"/><Setter Property="Margin" Value="0"/><Setter Property="Padding" Value="14,0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
    </Style>
    <Style Selector="Button.nav:pointerover"><Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/></Style>
    <Style Selector="Button.nav.selected"><Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/><Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/></Style>
    <Style Selector="Button.nav PathIcon"><Setter Property="Width" Value="20"/><Setter Property="Height" Value="20"/></Style>
    <Style Selector="Button.caption"><Setter Property="Width" Value="46"/><Setter Property="Height" Value="48"/><Setter Property="MinHeight" Value="48"/><Setter Property="Padding" Value="0"/><Setter Property="CornerRadius" Value="0"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/></Style>
    <Style Selector="Button.caption:pointerover"><Setter Property="Background" Value="#287F8C9B"/></Style>
    <Style Selector="Button.caption.close:pointerover"><Setter Property="Background" Value="#E81123"/><Setter Property="Foreground" Value="White"/></Style>
  </Window.Styles>

  <Grid RowDefinitions="48,*" Background="{DynamicResource CanvasBrush}">
    <Border x:Name="TitleBarDragRegion" Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" PointerPressed="OnTitleBarPointerPressed">
      <Grid ColumnDefinitions="48,Auto,*,Auto,138">
        <Button Classes="caption" Command="{Binding ToggleNavigationCommand}" ToolTip.Tip="展开或收起导航">
          <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="17"/>
        </Button>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="9" VerticalAlignment="Center" Margin="10,0,0,0" IsHitTestVisible="False">
          <Border Width="28" Height="28" Background="{DynamicResource AccentBrush}"><TextBlock Text="R" Foreground="White" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
          <TextBlock Text="RepoGalaxy" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Column="2" MaxWidth="620" MinWidth="180" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="18,0">
          <TextBox Classes="search" Text="{Binding SearchText}" PlaceholderText="{Binding SearchPlaceholder}" IsEnabled="{Binding CanSearch}" Padding="36,6,10,6" MinHeight="34"/>
          <PathIcon Data="{StaticResource IconSearch}" Width="16" Height="16" Margin="12,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" IsHitTestVisible="False"/>
        </Grid>

        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="8,0">
          <Border Classes="badge" VerticalAlignment="Center"><StackPanel Orientation="Horizontal" Spacing="6"><Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}"/><TextBlock Text="{Binding ConnectionStatus}"/></StackPanel></Border>
          <Button Classes="icon" Command="{Binding SyncCommand}" ToolTip.Tip="同步"><PathIcon Data="{StaticResource IconRefresh}" Width="17" Height="17"/></Button>
          <Button Classes="subtle" Command="{Binding LoginCommand}" IsVisible="{Binding !IsAuthenticated}" Content="登录 GitHub"/>
          <StackPanel IsVisible="{Binding IsAuthenticated}" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource AccentBrush}"><TextBlock Text="{Binding AccountInitial}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
            <TextBlock Text="{Binding CurrentUserLogin}" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Classes="ghost" Content="退出" Command="{Binding LogoutCommand}" Padding="6,2" MinHeight="28"/>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="4" Orientation="Horizontal">
          <Button Classes="caption" Click="OnMinimizeClick" ToolTip.Tip="最小化"><TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/></Button>
          <Button Classes="caption" Click="OnMaximizeClick" ToolTip.Tip="最大化或还原"><TextBlock x:Name="MaximizeIcon" Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/></Button>
          <Button Classes="caption close" Click="OnCloseClick" ToolTip.Tip="关闭"><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/></Button>
        </StackPanel>
      </Grid>
    </Border>

    <SplitView x:Name="NavigationSplit" Grid.Row="1" DisplayMode="CompactInline" IsPaneOpen="{Binding IsNavigationOpen}" OpenPaneLength="240" CompactPaneLength="48" PaneBackground="{DynamicResource SurfaceBrush}">
      <SplitView.Pane>
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
          <Grid RowDefinitions="Auto,*,Auto">
            <TextBlock Text="工作台" Classes="meta" Margin="16,14,0,8"/>
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
              <StackPanel>
                <ItemsControl ItemsSource="{Binding PrimaryNavigation}">
                  <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:NavigationItemViewModel"><controls:MetroRevealButton Classes="nav" Classes.selected="{Binding IsSelected}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).NavigateCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding Title}"><Grid ColumnDefinitions="4,30,*,Auto"><Border Background="{DynamicResource AccentBrush}" IsVisible="{Binding IsSelected}" Margin="-14,0,10,0"/><PathIcon Grid.Column="1" Data="{Binding Icon}" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding Title}" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/><Border Grid.Column="3" Classes="badge" IsVisible="{Binding BadgeCount}"><TextBlock Text="{Binding BadgeCount}"/></Border></Grid></controls:MetroRevealButton></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
                <Separator Margin="12,12"/>
                <TextBlock Text="仓库" Classes="meta" Margin="16,0,0,8"/>
                <ItemsControl ItemsSource="{Binding WorkspaceNavigation}">
                  <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:NavigationItemViewModel"><controls:MetroRevealButton Classes="nav" Classes.selected="{Binding IsSelected}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).NavigateCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding Title}"><Grid ColumnDefinitions="4,30,*"><Border Background="{DynamicResource AccentBrush}" IsVisible="{Binding IsSelected}" Margin="-14,0,10,0"/><PathIcon Grid.Column="1" Data="{Binding Icon}"/><TextBlock Grid.Column="2" Text="{Binding Title}" Margin="8,0,0,0" VerticalAlignment="Center"/></Grid></controls:MetroRevealButton></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
            <controls:MetroRevealButton Grid.Row="2" Classes="nav" Classes.selected="{Binding SettingsNavigation.IsSelected}" Command="{Binding NavigateCommand}" CommandParameter="{Binding SettingsNavigation}" ToolTip.Tip="设置"><Grid ColumnDefinitions="4,30,*"><Border Background="{DynamicResource AccentBrush}" IsVisible="{Binding SettingsNavigation.IsSelected}" Margin="-14,0,10,0"/><PathIcon Grid.Column="1" Data="{Binding SettingsNavigation.Icon}"/><TextBlock Grid.Column="2" Text="设置" Margin="8,0,0,0" VerticalAlignment="Center"/></Grid></controls:MetroRevealButton>
          </Grid>
        </Border>
      </SplitView.Pane>

      <SplitView x:Name="DetailsSplit" PanePlacement="Right" DisplayMode="Inline" IsPaneOpen="{Binding IsRightRailOpen}" OpenPaneLength="300" CompactPaneLength="0">
        <SplitView.Pane><ContentControl Content="{Binding RightRailContent}" Width="300"/></SplitView.Pane>
        <Grid RowDefinitions="40,*">
          <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,0">
            <Grid ColumnDefinitions="*,Auto"><StackPanel Orientation="Horizontal" Spacing="12"><TextBlock Text="{Binding CurrentViewName}" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBlock Text="{Binding SyncStatus}" Classes="meta" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="520"/></StackPanel><Button Grid.Column="1" Classes="subtle" Command="{Binding ToggleRightRailCommand}" Content="侧栏" IsVisible="{Binding CanToggleRightRail}" MinHeight="30" Padding="10,3" VerticalAlignment="Center"/></Grid>
          </Border>
          <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
      </SplitView>
    </SplitView>
  </Grid>
</Window>
