<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RepoGalaxy.Desktop.ViewModels"
        xmlns:controls="using:RepoGalaxy.Desktop.Controls"
        x:Class="RepoGalaxy.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="RepoGalaxy"
        Icon="/Assets/repogalaxy.ico"
        Width="1440" Height="900"
        WindowStartupLocation="CenterScreen"
        MinWidth="900" MinHeight="640"
        CanResize="True"
        WindowDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="48"
        Win32Properties.WindowCornerPreference="DoNotRound">
  <Window.Styles>
    <Style Selector="Button.nav">
      <Setter Property="Height" Value="48"/><Setter Property="Margin" Value="0"/><Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
    </Style>
    <Style Selector="Button.nav:pointerover"><Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/></Style>
    <Style Selector="Button.nav.selected"><Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/><Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/></Style>
    <Style Selector="Button.caption"><Setter Property="Width" Value="46"/><Setter Property="Height" Value="48"/><Setter Property="MinHeight" Value="48"/><Setter Property="Padding" Value="0"/><Setter Property="CornerRadius" Value="0"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/></Style>
    <Style Selector="Button.caption:pointerover"><Setter Property="Background" Value="#287F8C9B"/></Style>
    <Style Selector="Button.caption.close:pointerover"><Setter Property="Background" Value="#E81123"/><Setter Property="Foreground" Value="White"/></Style>
    <Style Selector="ListBox.search-results">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>
    <Style Selector="ListBox.search-results > ListBoxItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0,0,0,3"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBox.search-results > ListBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}"/>
    </Style>
    <Style Selector="ListBox.search-results > ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="48,*" Background="{DynamicResource CanvasBrush}">
    <Border x:Name="TitleBarDragRegion" Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto,138">
        <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center" Margin="16,0,12,0" IsHitTestVisible="False">
          <controls:RepoGalaxyMark x:Name="HeaderBrandMark" Width="28" Height="28"/>
          <TextBlock Text="RepoGalaxy" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid x:Name="SearchRegion" Grid.Column="1" MaxWidth="680" MinWidth="180" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="18,0">
          <Border Background="{DynamicResource SurfaceMutedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <TextBox x:Name="SearchBox" Classes="search" Text="{Binding SearchText}" PlaceholderText="{Binding SearchPlaceholder}" IsEnabled="{Binding CanSearch}" Padding="36,6,112,6" MinHeight="34" Background="Transparent" BorderThickness="0"/>
          </Border>
          <PathIcon Data="{StaticResource IconSearch}" Width="16" Height="16" Margin="12,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" IsHitTestVisible="False"/>
          <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="4" Margin="0,0,6,0">
            <TextBlock Text="{Binding SearchMatchText}" Classes="meta" VerticalAlignment="Center"/>
            <Button Classes="icon" IsVisible="{Binding HasSearchText}" Command="{Binding ClearSearchCommand}" ToolTip.Tip="清除搜索" Width="28" Height="28"><PathIcon Data="{StaticResource IconClose}" Width="12" Height="12"/></Button>
          </StackPanel>
          <Popup IsOpen="{Binding IsSearchPanelOpen, Mode=TwoWay}" PlacementTarget="{Binding #SearchBox}" Placement="BottomEdgeAlignedLeft" IsLightDismissEnabled="True">
            <Border Width="640" MaxHeight="460" Margin="0,7,0,0"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1">
              <Grid RowDefinitions="3,Auto,*">
                <Border Background="{DynamicResource AccentBrush}"/>
                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="16,12,16,10">
                  <StackPanel Spacing="2">
                    <TextBlock Text="搜索当前页面" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="仅检索已经加载到本地的内容" Classes="meta"/>
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="↑↓ 选择  ·  Enter 定位  ·  Esc 关闭"
                             Classes="meta" VerticalAlignment="Center"/>
                </Grid>
                <StackPanel Grid.Row="2" Spacing="7" Margin="10,0,10,10">
                <StackPanel IsVisible="{Binding !HasSearchText}" Spacing="7" Margin="6,2">
                  <TextBlock Text="最近搜索" Classes="meta" IsVisible="{Binding HasRecentSearches}"/>
                  <ItemsControl ItemsSource="{Binding RecentSearches}" IsVisible="{Binding HasRecentSearches}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Button Classes="subtle" Margin="0,0,6,6" Padding="10,5"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).UseRecentSearchCommand}"
                                CommandParameter="{Binding}">
                          <TextBlock Text="{Binding}"/>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
                <ListBox Classes="search-results"
                         ItemsSource="{Binding SearchSuggestions}"
                         SelectedIndex="{Binding SelectedSearchSuggestionIndex, Mode=TwoWay}"
                         MaxHeight="330">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Button Classes="ghost" Padding="10,9" HorizontalContentAlignment="Stretch"
                              Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ActivateSearchSuggestionCommand}"
                              CommandParameter="{Binding}">
                        <Grid ColumnDefinitions="72,*,Auto" ColumnSpacing="11">
                          <Border Background="{DynamicResource SurfaceMutedBrush}" Padding="7,4" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Kind}" Foreground="{DynamicResource AccentTextBrush}" FontSize="11" FontWeight="SemiBold"/>
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Subtitle}" Classes="meta" TextTrimming="CharacterEllipsis"/>
                          </StackPanel>
                          <PathIcon Grid.Column="2" Data="{StaticResource IconChevronRight}" Width="14" Height="14"
                                    VerticalAlignment="Center" Foreground="{DynamicResource TertiaryTextBrush}"/>
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <Border IsVisible="{Binding ShowSearchEmptyState}"
                        Background="{DynamicResource SurfaceMutedBrush}" Padding="14,12" Margin="6,2">
                  <StackPanel Spacing="3">
                    <TextBlock Text="没有找到匹配内容" FontWeight="SemiBold"/>
                    <TextBlock Text="可以尝试仓库名、语言、Topic 或推荐理由；这里不会发起 GitHub 请求。"
                               Classes="meta" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
                </StackPanel>
              </Grid>
            </Border>
          </Popup>
        </Grid>

        <StackPanel x:Name="AccountRegion" Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="8,0">
          <Border Classes="badge" VerticalAlignment="Center"><StackPanel Orientation="Horizontal" Spacing="6"><Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessBrush}"/><TextBlock x:Name="ConnectionStatusText" Text="{Binding ConnectionStatus}"/></StackPanel></Border>
          <Button Classes="subtle" Command="{Binding LoginCommand}" IsVisible="{Binding !IsAuthenticated}" Content="登录 GitHub"/>
          <Button IsVisible="{Binding IsAuthenticated}" Classes="ghost" Padding="4" ToolTip.Tip="账户资料" Command="{Binding OpenAccountProfileCommand}">
            <Button.Flyout>
              <Flyout Placement="BottomEdgeAlignedRight">
                <Border Width="360" Padding="18" Background="{DynamicResource SurfaceElevatedBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                  <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="64,*" ColumnSpacing="14">
                      <Grid Width="64" Height="64">
                        <Border CornerRadius="32" Background="{DynamicResource AccentBrush}"><TextBlock Text="{Binding AccountProfile.Initial}" Foreground="White" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                        <Border CornerRadius="32" ClipToBounds="True" IsVisible="{Binding AccountProfile.HasAvatar}"><Image Source="{Binding AccountProfile.Avatar}" Stretch="UniformToFill"/></Border>
                      </Grid>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3"><TextBlock Text="{Binding AccountProfile.DisplayName}" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="{Binding AccountProfile.LoginText}" Classes="meta"/><TextBlock Text="{Binding AccountProfile.Context}" Classes="meta" TextWrapping="Wrap"/></StackPanel>
                    </Grid>
                    <TextBlock Text="{Binding AccountProfile.User.Bio}" TextWrapping="Wrap" MaxLines="4"/>
                    <TextBlock Text="{Binding AccountProfile.Statistics}" Classes="meta" TextWrapping="Wrap"/>
                    <ItemsControl ItemsSource="{Binding AccountProfile.SocialAccounts}">
                      <ItemsControl.ItemTemplate><DataTemplate><Button Classes="ghost" HorizontalContentAlignment="Left" Padding="0,5" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AccountProfile.OpenUrlCommand}" CommandParameter="{Binding Url}"><StackPanel Orientation="Horizontal" Spacing="8"><PathIcon Data="{StaticResource IconLink}" Width="15" Height="15"/><TextBlock Text="{Binding Provider}"/><TextBlock Text="{Binding Url}" Classes="meta" TextTrimming="CharacterEllipsis" MaxWidth="235"/></StackPanel></Button></DataTemplate></ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding AccountProfile.Status}" Classes="meta"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"><Button Classes="primary" Content="打开 GitHub 主页" Command="{Binding AccountProfile.OpenUrlCommand}" CommandParameter="{Binding AccountProfile.User.ProfileUrl}"/><Button Grid.Column="1" Classes="subtle" Content="退出登录" Command="{Binding LogoutCommand}"/></Grid>
                  </StackPanel>
                </Border>
              </Flyout>
            </Button.Flyout>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Grid Width="28" Height="28"><Border CornerRadius="14" Background="{DynamicResource AccentBrush}"><TextBlock Text="{Binding AccountProfile.Initial}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><Border CornerRadius="14" ClipToBounds="True" IsVisible="{Binding AccountProfile.HasAvatar}"><Image Source="{Binding AccountProfile.Avatar}" Stretch="UniformToFill"/></Border></Grid>
              <TextBlock x:Name="AccountNameText" Text="{Binding CurrentUserLogin}" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal">
          <Button x:Name="MinimizeButton" Classes="caption" Click="OnMinimizeClick" ToolTip.Tip="最小化"><Grid Width="20" Height="20"><Path x:Name="MinimizeIcon" Data="M3,10 L17,10" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid></Button>
          <Button x:Name="MaximizeButton" Classes="caption" Click="OnMaximizeClick" ToolTip.Tip="最大化或还原"><Grid Width="20" Height="20"><Path x:Name="MaximizeIcon" Data="M3,3 L17,3 L17,17 L3,17 Z" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1" Fill="Transparent" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid></Button>
          <Button x:Name="CloseButton" Classes="caption close" Click="OnCloseClick" ToolTip.Tip="关闭"><Grid Width="20" Height="20"><Path x:Name="CloseIcon" Data="M3,3 L17,17 M17,3 L3,17" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid></Button>
        </StackPanel>
      </Grid>
    </Border>

    <SplitView x:Name="NavigationSplit" Grid.Row="1" DisplayMode="CompactInline" IsPaneOpen="{Binding IsNavigationOpen}" OpenPaneLength="216" CompactPaneLength="48" PaneBackground="{DynamicResource SurfaceBrush}">
      <SplitView.Pane>
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
          <Grid RowDefinitions="48,Auto,*,Auto">
            <controls:MetroRevealButton x:Name="NavigationToggleButton" Classes="nav" Command="{Binding ToggleNavigationCommand}" ToolTip.Tip="展开或收起导航"><Grid Width="48" Height="48"><PathIcon Data="M3,5 L17,5 M3,10 L17,10 M3,15 L17,15" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid></controls:MetroRevealButton>
            <TextBlock Grid.Row="1" Text="工作台" Classes="meta" Margin="16,10,0,8" IsVisible="{Binding IsNavigationOpen}"/>
            <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
              <StackPanel>
                <ItemsControl ItemsSource="{Binding PrimaryNavigation}">
                  <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:NavigationItemViewModel"><controls:MetroRevealButton Classes="nav" Classes.selected="{Binding IsSelected}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).NavigateCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding Title}"><Grid ColumnDefinitions="48,*,Auto"><Border Width="4" HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}" IsVisible="{Binding IsSelected}"/><Grid Width="48" Height="48"><PathIcon Data="{Binding Icon}" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid><TextBlock Grid.Column="1" Text="{Binding Title}" Margin="8,0,0,0" VerticalAlignment="Center" FontWeight="Medium"/><Border Grid.Column="2" Classes="badge" IsVisible="{Binding BadgeCount}" Margin="0,0,10,0"><TextBlock Text="{Binding BadgeCount}"/></Border></Grid></controls:MetroRevealButton></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
                <Separator Margin="12,12"/>
                <TextBlock Text="仓库" Classes="meta" Margin="16,0,0,8" IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsNavigationOpen}"/>
                <ItemsControl ItemsSource="{Binding WorkspaceNavigation}">
                  <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:NavigationItemViewModel"><controls:MetroRevealButton Classes="nav" Classes.selected="{Binding IsSelected}" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).NavigateCommand}" CommandParameter="{Binding}" ToolTip.Tip="{Binding Title}"><Grid ColumnDefinitions="48,*"><Border Width="4" HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}" IsVisible="{Binding IsSelected}"/><Grid Width="48" Height="48"><PathIcon Data="{Binding Icon}" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid><TextBlock Grid.Column="1" Text="{Binding Title}" Margin="8,0,0,0" VerticalAlignment="Center"/></Grid></controls:MetroRevealButton></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
            <controls:MetroRevealButton Grid.Row="3" Classes="nav" Classes.selected="{Binding SettingsNavigation.IsSelected}" Command="{Binding NavigateCommand}" CommandParameter="{Binding SettingsNavigation}" ToolTip.Tip="设置"><Grid ColumnDefinitions="48,*"><Border Width="4" HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}" IsVisible="{Binding SettingsNavigation.IsSelected}"/><Grid Width="48" Height="48"><PathIcon Data="{Binding SettingsNavigation.Icon}" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid><TextBlock Grid.Column="1" Text="设置" Margin="8,0,0,0" VerticalAlignment="Center"/></Grid></controls:MetroRevealButton>
          </Grid>
        </Border>
      </SplitView.Pane>

      <SplitView x:Name="DetailsSplit" PanePlacement="Right" DisplayMode="Inline" IsPaneOpen="{Binding IsRightRailOpen}" OpenPaneLength="300" CompactPaneLength="0">
        <SplitView.Pane>
          <Border Width="300" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0">
            <Grid RowDefinitions="48,*">
              <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,0">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="4">
                  <Button Classes="icon" Command="{Binding CloseRepositoryDetailsCommand}"
                          IsVisible="{Binding IsRepositoryDetailsMode}" ToolTip.Tip="返回工作台">
                    <PathIcon Data="{StaticResource IconBack}" Width="16" Height="16"/>
                  </Button>
                  <TextBlock Grid.Column="1" Text="{Binding RightRailTitle}" FontWeight="SemiBold"
                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                  <Button Grid.Column="2" Classes="subtle" Command="{Binding SyncCommand}"
                          IsEnabled="{Binding !DashboardRail.IsSyncing}" ToolTip.Tip="同步当前 Feed"
                          Padding="8,4" MinHeight="30">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <PathIcon Data="{StaticResource IconSync}" Width="14" Height="14"/>
                      <TextBlock Text="同步"/>
                    </StackPanel>
                  </Button>
                  <Button Grid.Column="3" Classes="icon" Command="{Binding CloseRepositoryDetailsCommand}"
                          IsVisible="{Binding IsRepositoryDetailsMode}" ToolTip.Tip="关闭详情">
                    <PathIcon Data="{StaticResource IconClose}" Width="16" Height="16"/>
                  </Button>
                </Grid>
              </Border>
              <ContentControl Grid.Row="1" Content="{Binding RightRailContent}"/>
            </Grid>
          </Border>
        </SplitView.Pane>
        <Grid RowDefinitions="40,*">
          <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,0">
            <Grid ColumnDefinitions="*,Auto"><StackPanel Orientation="Horizontal" Spacing="12"><TextBlock Text="{Binding CurrentViewName}" FontWeight="SemiBold" VerticalAlignment="Center"/><TextBlock Text="{Binding SyncStatus}" Classes="meta" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="520"/></StackPanel><Button Grid.Column="1" Classes="subtle" Command="{Binding ToggleRightRailCommand}" Content="侧栏" IsVisible="{Binding CanToggleRightRail}" MinHeight="30" Padding="10,3" VerticalAlignment="Center"/></Grid>
          </Border>
          <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
        </Grid>
      </SplitView>
    </SplitView>
    <Grid x:Name="ResizeChrome" Grid.RowSpan="2" Panel.ZIndex="20000">
      <Border x:Name="ResizeNorth" Height="6" VerticalAlignment="Top" Margin="8,0" Background="Transparent"/>
      <Border x:Name="ResizeSouth" Height="6" VerticalAlignment="Bottom" Margin="8,0" Background="Transparent"/>
      <Border x:Name="ResizeWest" Width="6" HorizontalAlignment="Left" Margin="0,8" Background="Transparent"/>
      <Border x:Name="ResizeEast" Width="6" HorizontalAlignment="Right" Margin="0,8" Background="Transparent"/>
      <Border x:Name="ResizeNorthWest" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent"/>
      <Border x:Name="ResizeNorthEast" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent"/>
      <Border x:Name="ResizeSouthWest" Width="8" Height="8" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent"/>
      <Border x:Name="ResizeSouthEast" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent"/>
    </Grid>
  </Grid>
</Window>
