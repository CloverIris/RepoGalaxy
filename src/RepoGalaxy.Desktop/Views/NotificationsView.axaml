<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="RepoGalaxy.Desktop.Views.NotificationsView" x:CompileBindings="False"><Grid Margin="24" RowDefinitions="Auto,*"><TextBlock Text="Notifications" FontSize="28" FontWeight="SemiBold"/><ListBox Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,16,0,0"><ListBox.ItemTemplate><DataTemplate><Grid ColumnDefinitions="*,Auto" Margin="12"><StackPanel><TextBlock Text="{Binding Repository.FullName}" FontWeight="SemiBold"/><TextBlock Text="{Binding Reason.Summary}" Opacity="0.7"/></StackPanel><Button Grid.Column="1" Content="Mark read" Command="{Binding DataContext.ReadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Id}"/></Grid></DataTemplate></ListBox.ItemTemplate></ListBox></Grid></UserControl>
